{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/acadia/refs/heads/main/json-structure/acadia-skill-record-structure.json",
  "name": "SkillRecord",
  "description": "A skill record in the employee skills matrix",
  "type": "object",
  "properties": {
    "skillId": {
      "type": "string",
      "description": "Unique skill identifier",
      "example": "skill-001"
    },
    "name": {
      "type": "string",
      "description": "Skill name",
      "example": "Machine Startup"
    },
    "required": {
      "type": "boolean",
      "description": "Whether this skill is required for the role",
      "example": true
    },
    "completed": {
      "type": "boolean",
      "description": "Whether the employee has completed this skill",
      "example": true
    },
    "completedAt": {
      "type": "datetime",
      "description": "When the skill was completed",
      "example": "2026-02-10T08:00:00Z"
    },
    "score": {
      "type": "int32",
      "description": "Score achieved (0-100)",
      "example": 95
    }
  }
}