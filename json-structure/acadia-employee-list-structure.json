{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/acadia/refs/heads/main/json-structure/acadia-employee-list-structure.json",
  "name": "EmployeeList",
  "description": "Paginated list of employees",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Employee"
      }
    },
    "total": {
      "type": "int32",
      "example": 150
    },
    "page": {
      "type": "int32",
      "example": 1
    },
    "limit": {
      "type": "int32",
      "example": 25
    }
  }
}