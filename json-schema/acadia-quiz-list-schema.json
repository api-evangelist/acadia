{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/acadia/refs/heads/main/json-schema/acadia-quiz-list-schema.json",
  "title": "QuizList",
  "description": "Paginated list of quizzes",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Quiz"
      }
    },
    "total": {
      "type": "integer",
      "example": 15
    },
    "page": {
      "type": "integer",
      "example": 1
    },
    "limit": {
      "type": "integer",
      "example": 25
    }
  }
}